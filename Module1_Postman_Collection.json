{
    "info": {
        "_postman_id": "module-1-vaccine-management",
        "name": "Module 1 - Vaccine Management API",
        "description": "API untuk mengelola Health Centers, Vaccines, Vaccine Stocks, dan Vaccine Schedules - Create-Then-Delete Pattern untuk unlimited testing",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Health Centers",
            "item": [
                {
                    "name": "List All Health Centers",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers?per_page=15",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers"],
                            "query": [
                                {
                                    "key": "per_page",
                                    "value": "15"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Health Center By ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/4",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers", "4"]
                        }
                    }
                },
                {
                    "name": "Get Active Health Centers",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/active",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers", "active"]
                        }
                    }
                },
                {
                    "name": "Search Health Centers",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/search?q=jakarta",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers", "search"],
                            "query": [
                                {
                                    "key": "q",
                                    "value": "jakarta"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Health Centers By Province",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/by-province/JAKARTA",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers", "by-province", "JAKARTA"]
                        }
                    }
                },
                {
                    "name": "Get Health Centers By City",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/by-city/JAKARTA%20PUSAT",
                            "host": ["{{base_url}}"],
                            "path": [
                                "health-centers",
                                "by-city",
                                "JAKARTA%20PUSAT"
                            ]
                        }
                    }
                },
                {
                    "name": "[CRUD] 1. Create Test Health Center",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    let responseJson = pm.response.json();",
                                    "    pm.collectionVariables.set('test_health_center_id', responseJson.data.id);",
                                    "    console.log('Test Health Center ID: ' + responseJson.data.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Puskesmas Test {{$timestamp}}\",\n  \"code\": \"TST-{{$randomInt}}-{{$timestamp}}\",\n  \"address\": \"Jalan Test No. {{$randomInt}}\",\n  \"province\": \"JAWA BARAT\",\n  \"city\": \"BANDUNG\",\n  \"district\": \"Kecamatan Test\",\n  \"village\": \"Kelurahan Test\",\n  \"latitude\": -6.9175,\n  \"longitude\": 107.6087,\n  \"phone\": \"+62-274123456\",\n  \"capacity\": 100,\n  \"status\": \"active\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/health-centers",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers"]
                        }
                    }
                },
                {
                    "name": "[CRUD] 2. Get Test Health Center By ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/{{test_health_center_id}}",
                            "host": ["{{base_url}}"],
                            "path": [
                                "health-centers",
                                "{{test_health_center_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "[CRUD] 3. Update Test Health Center",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"capacity\": 250,\n  \"status\": \"active\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/health-centers/{{test_health_center_id}}",
                            "host": ["{{base_url}}"],
                            "path": [
                                "health-centers",
                                "{{test_health_center_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "[CRUD] 4. Delete Test Health Center",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health-centers/{{test_health_center_id}}",
                            "host": ["{{base_url}}"],
                            "path": [
                                "health-centers",
                                "{{test_health_center_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Static Health Center (for testing existing data)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Puskesmas Baru\",\n  \"code\": \"PBR-00001\",\n  \"address\": \"Jalan Kesehatan No. 1\",\n  \"province\": \"JAWA BARAT\",\n  \"city\": \"BANDUNG\",\n  \"district\": \"Kecamatan Bandung\",\n  \"village\": \"Kelurahan Test\",\n  \"latitude\": -6.9175,\n  \"longitude\": 107.6087,\n  \"phone\": \"+62-274123456\",\n  \"capacity\": 100,\n  \"status\": \"active\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/health-centers",
                            "host": ["{{base_url}}"],
                            "path": ["health-centers"]
                        }
                    }
                }
            ]
        },
